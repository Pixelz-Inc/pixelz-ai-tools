# Pixelz Platform API
PIXELZ_PLATFORM_EMAIL=your_email@example.com
PIXELZ_PLATFORM_API_KEY=your_platform_api_key

# Pixelz Automation API
PIXELZ_AUTOMATION_CLIENT_ID=your_client_id
PIXELZ_AUTOMATION_CLIENT_SECRET=your_client_secret

# Logging (optional)
# Set a file path to enable logging of API requests, responses, and errors.
# Leave commented out or empty to disable file logging.
# PIXELZ_LOG_FILE=/path/to/pixelz.log
