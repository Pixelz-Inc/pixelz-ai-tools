# Supply chain security hardening (pnpm v10)

# Quarantine: only install package versions published at least 7 days ago.
# This gives the community time to discover and flag compromised releases.
minimum-release-age=10080

# Block lifecycle scripts in dependencies by default.
# pnpm v10 does this automatically; this makes the intent explicit.
# To allow a specific package's build scripts, add it to the allowBuilds list below.
ignore-scripts=true

# Pin exact versions when adding dependencies — no ^ or ~ ranges.
save-exact=true

# Block transitive dependencies that use git repos or tarball URLs.
block-exotic-subdeps=true

# Prevent installation if a package's trust level decreased vs previous releases.
trust-policy=no-downgrade

# Use pnpm install --frozen-lockfile in CI/CD pipelines.
